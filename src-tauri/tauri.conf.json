{
  "productName": "Command",
  "version": "2.0.0",
  "identifier": "com.hivenet.app",
  "build": {
    "beforeDevCommand": "bun run dev:web",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../backend/**/*.cjs", "resources/bin/index.bundled.cjs"],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13"
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Command",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "shadow": false,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 18 },
        "windowEffects": {
          "state": "active",
          "effects": ["underWindowBackground"]
        }
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:hive.db"]
    },
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}

                                          "fontFamily": "Inter",
                                          "fontSize": 14,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "YO3Y9",
                                          "name": "text",
                                          "fill": "#C0C0C0",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "The SDK env config (which they do correctly)",
                                          "fontFamily": "Inter",
                                          "fontSize": 14,
                                          "fontWeight": "normal"
                                        }
                                      ]
                                    },
                                    {
                                      "type": "frame",
                                      "id": "Fenkp",

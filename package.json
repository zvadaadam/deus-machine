    "tauri:dev": "tauri dev",
    "// tauri:dev": "🚀 DESKTOP APP - Runs EVERYTHING (Vite + Backend + Tauri). This is what you want for desktop development!",
    "dev:full": "./dev.sh",
    "// dev:full": "🌐 WEB DEV - Runs backend + frontend together with proper port setup. Use this for web-only development.",

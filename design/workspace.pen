                      "fill": "#E6EDF3",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The updateCodexAuth() function reads from process.env.OPENAI_API_KEY and writes it to ~/.codex/auth.json. This is because the Codex CLI requires both:",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "X8dza",
                      "name": "listContainer",
                      "width": "fill_container",
                      "layout": "vertical",
                      "gap": 4,
                      "padding": [
                        0,
                        0,
                        0,
                        16
                      ],
                      "children": [
                        {
                          "id": "AJoF9",
                          "type": "ref",
                          "ref": "c7HdI",
                          "name": "listItem1",
                          "width": "fill_container",
                          "descendants": {
                            "OsrPW": {
                              "content": "1.",
                              "fill": "#8B949E"
                            },
                            "5GhqL": {
                              "content": "The SDK env config (which they do correctly)",
                              "fill": "#E6EDF3"
                            }
                          }
                        },
                        {
                          "id": "ZRS6P",
                          "type": "ref",
                          "ref": "c7HdI",
                          "name": "listItem2",
                          "width": "fill_container",
                          "descendants": {
                            "OsrPW": {
                              "content": "2.",
                              "fill": "#8B949E"
                            },

{
  "name": "conductor",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "//": "═══════════════════════════════════════════════════════════════",
    "// MAIN COMMANDS": "Use these for development:",
    "//1": "═══════════════════════════════════════════════════════════════",
    "tauri:dev": "tauri dev",
    "// tauri:dev": "🚀 DESKTOP APP - Runs EVERYTHING (Vite + Backend + Tauri). This is what you want for desktop development!",
    "dev:full": "./scripts/dev.sh",
    "// dev:full": "🌐 WEB DEV - Runs backend + frontend together with proper port setup. Use this for web-only development.",
    "//2": "═══════════════════════════════════════════════════════════════",
    "// INDIVIDUAL COMPONENTS": "⚠️  DON'T run these separately unless you know what you're doing!",
    "//3": "═══════════════════════════════════════════════════════════════",
    "dev": "vite",
    "// dev": "⚠️  Frontend only - requires backend running separately. Use 'dev:full' or 'tauri:dev' instead!",
    "dev:backend": "node backend/server.cjs",
    "// dev:backend": "⚠️  Backend only - requires frontend running separately. Use 'dev:full' or 'tauri:dev' instead!",
    "//4": "═══════════════════════════════════════════════════════════════",
    "// BUILD & PRODUCTION": "",
    "//5": "═══════════════════════════════════════════════════════════════",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "//6": "═══════════════════════════════════════════════════════════════",
    "// TESTING": "",
    "//7": "═══════════════════════════════════════════════════════════════",
    "test": "node tests/e2e-flow.test.cjs",
    "// test": "🧪 Run E2E test suite - requires backend running",
    "//8": "═══════════════════════════════════════════════════════════════",
    "// CODE FORMATTING": "",
    "//9": "═══════════════════════════════════════════════════════════════",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "// format": "✨ Format all code with Prettier + auto-sort Tailwind classes",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "// format:check": "🔍 Check if code is properly formatted (useful for CI)",
    "lint": "eslint src --ext .ts,.tsx",
    "// lint": "🔍 Check code for issues with ESLint",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "// lint:fix": "🔧 Auto-fix ESLint issues where possible",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.0.0",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.33.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@shikijs/rehype": "^3.14.0",
    "@shikijs/transformers": "^3.14.0",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-http": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-sql": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "better-sqlite3": "^12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "diff": "^8.0.2",
    "express": "^5.1.0",
    "framer-motion": "^12.23.24",
    "immer": "^11.0.1",
    "lucide-react": "^0.546.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "react-router-dom": "^6.26.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.25",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^5.4.1"
  }
}

# ============================================================================
# API Keys for AI agents (used by agent-server)
# ============================================================================

# Anthropic API Key (required for Claude agent)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI API Key (required for Codex agent)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Deus Cloud API Key (required for cloud workspaces)
DEUS_API_KEY=

# ============================================================================
# Optional overrides
# ============================================================================

# Deus Cloud API base URL
DEUS_BASE_URL=

# Claude CLI path — set when Claude is installed in a non-standard location
# Example: CLAUDE_CLI_PATH=/opt/homebrew/bin/claude
CLAUDE_CLI_PATH=

# Sentry auth token — only needed for CI source map uploads
# Get your token at: https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=

                              },
                              "descendants": {
                                "ZsMjg": {
                                  "content": "// Update OPENAI_API_KEY in process.env and write auth.json for Codex CLI\n// This is necessary because Codex CLI reads from ~/.codex/auth.json, not just env vars\nprocess.env.OPENAI_API_KEY = apiKey;\nupdateCodexAuth();",
                                  "fill": "#E6EDF3",
                                  "width": "fill_container",
                                  "height": 0,
                                  "x": 16,
                                  "y": 12
                                }
                              }
                            },
                            {
                              "type": "text",
                              "id": "baKq2",
                              "name": "para2",
                              "fill": "#E6EDF3",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "The updateCodexAuth() function reads from process.env.OPENAI_API_KEY and writes it to ~/.codex/auth.json. This is because the Codex CLI requires both:",
                              "fontFamily": "Inter",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "frame",
                              "id": "1WMme",
                              "name": "listContainer",
                              "width": "fill_container",

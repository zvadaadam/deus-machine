{
  "name": "conductor",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:sidecar && tauri dev",
    "dev:web": "./scripts/dev.sh",
    "dev:frontend": "vite",
    "dev:backend": "node backend/server.cjs",
    "build": "npm run build:sidecar && tsc && vite build",
    "build:tauri": "npm run build:sidecar && tauri build",
    "build:sidecar": "npx tsx sidecar/build.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run --config backend/vitest.config.ts && vitest run --config sidecar/vitest.config.ts",
    "test:e2e": "node tests/e2e-flow.test.cjs",
    "test:backend": "vitest run --config backend/vitest.config.ts",
    "test:backend:watch": "vitest --config backend/vitest.config.ts",
    "test:sidecar": "vitest run --config sidecar/vitest.config.ts",
    "test:sidecar:watch": "vitest --config sidecar/vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },

                                  "width": "fill_container",
                                  "descendants": {
                                    "OsrPW": {
                                      "content": "1.",
                                      "fill": "#8B949E"
                                    },
                                    "5GhqL": {
                                      "content": "The SDK env config (which they do correctly)",
                                      "fill": "#E6EDF3"
                                    }
                                  }
                                },
                                {
                                  "id": "lMrvx",
                                  "type": "ref",
                                  "ref": "c7HdI",
                                  "name": "listItem2",
                                  "width": "fill_container",
                                  "descendants": {
                                    "OsrPW": {
                                      "content": "2.",
                                      "fill": "#8B949E"
                                    },
                                    "5GhqL": {
                                      "content": "The file ~/.codex/auth.json (legacy requirement)",
                                      "fill": "#E6EDF3"
